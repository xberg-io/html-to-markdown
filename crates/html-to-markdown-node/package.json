{
	"name": "html-to-markdown",
	"version": "3.1.0",
	"description": "High-performance HTML to Markdown converter (native Node.js binding)",
	"license": "MIT",
	"main": "index.js",
	"types": "index.d.ts",
	"scripts": {
		"build": "napi build --manifest-path Cargo.toml --release --output-dir .",
		"build:debug": "napi build --manifest-path Cargo.toml --output-dir ."
	},
	"napi": {
		"binaryName": "html-to-markdown-rs",
		"triples": [
			"x86_64-unknown-linux-gnu",
			"x86_64-apple-darwin",
			"aarch64-apple-darwin",
			"x86_64-pc-windows-msvc"
		]
	},
	"devDependencies": {
		"@napi-rs/cli": "^3.6.1"
	},
	"files": [
		"index.js",
		"index.d.ts",
		"**/*.node"
	]
}
