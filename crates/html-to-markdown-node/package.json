{
  "name": "@xberg-io/html-to-markdown",
  "version": "3.8.0-rc.2",
  "description": "High-performance HTML to Markdown converter",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xberg-io/html-to-markdown.git"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    }
  },
  "files": ["index.js", "index.d.ts", "*.node"],
  "optionalDependencies": {
    "@xberg-io/html-to-markdown-linux-x64-gnu": "3.8.0-rc.2",
    "@xberg-io/html-to-markdown-linux-arm64-gnu": "3.8.0-rc.2",
    "@xberg-io/html-to-markdown-linux-x64-musl": "3.8.0-rc.2",
    "@xberg-io/html-to-markdown-linux-arm64-musl": "3.8.0-rc.2",
    "@xberg-io/html-to-markdown-darwin-x64": "3.8.0-rc.2",
    "@xberg-io/html-to-markdown-darwin-arm64": "3.8.0-rc.2",
    "@xberg-io/html-to-markdown-win32-x64-msvc": "3.8.0-rc.2",
    "@xberg-io/html-to-markdown-win32-arm64-msvc": "3.8.0-rc.2"
  },
  "napi": {
    "packageName": "@xberg-io/html-to-markdown",
    "binaryName": "html-to-markdown-node",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "npx --yes -p @napi-rs/cli@^3.6.2 napi build --platform --release",
    "artifacts": "npx --yes -p @napi-rs/cli@^3.6.2 napi artifacts",
    "prepublishOnly": "npx --yes -p @napi-rs/cli@^3.6.2 napi prepublish -t npm --skip-optional-publish"
  },
  "engines": { "node": ">= 18" },
  "publishConfig": { "access": "public" },
  "devDependencies": { "@napi-rs/cli": "^3.6.2" }
}
