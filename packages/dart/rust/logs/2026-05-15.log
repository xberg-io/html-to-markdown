impl From<html_to_markdown_rs::NodeContent> for NodeContent {
    fn from(v: html_to_markdown_rs::NodeContent) -> Self {
        match v {
            html_to_markdown_rs::NodeContent::Heading { level, text } =>
                NodeContent::Heading { level: level as _, text },
            html_to_markdown_rs::NodeContent::Paragraph { text } =>
                NodeContent::Paragraph { text },
            html_to_markdown_rs::NodeContent::List { ordered } =>
                NodeContent::List { ordered: ordered as _ },
            html_to_markdown_rs::NodeContent::ListItem { text } =>
                NodeContent::ListItem { text },
            html_to_markdown_rs::NodeContent::Table { grid } =>
                NodeContent::Table { grid: TableGrid::from(grid) },
            html_to_markdown_rs::NodeContent::Image {
                description, src, image_index } =>
                NodeContent::Image {
                    description: description.unwrap_or_default(),
                    src: src.unwrap_or_default(),
                    image_index: image_index.map(|x| x as _).unwrap_or_default(),
                },
            html_to_markdown_rs::NodeContent::Code { text, language } =>
                NodeContent::Code {
                    text,
                    language: language.unwrap_or_default(),
                },
            html_to_markdown_rs::NodeContent::Quote => NodeContent::Quote,
            html_to_markdown_rs::NodeContent::DefinitionList =>
                NodeContent::DefinitionList,
            html_to_markdown_rs::NodeContent::DefinitionItem {
                term, definition } => {
                NodeContent::DefinitionItem { term, definition }
            }
            html_to_markdown_rs::NodeContent::RawBlock { format, content } =>
                NodeContent::RawBlock { format, content },
            html_to_markdown_rs::NodeContent::MetadataBlock { entries } =>
                NodeContent::MetadataBlock {
                    entries: entries.into_iter().map(|e|
