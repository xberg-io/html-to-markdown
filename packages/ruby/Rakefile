# frozen_string_literal: true

require "bundler"
Bundler::GemHelper.install_tasks name: "html_to_markdown"
require "rake/extensiontask"
require "rspec/core/rake_task"

GEM_ROOT = __dir__
GEMSPEC = Gem::Specification.load(File.expand_path("html_to_markdown.gemspec", GEM_ROOT))

Rake::ExtensionTask.new("html-to-markdown-rb", GEMSPEC) do |ext|
  ext.lib_dir = "lib"
  ext.ext_dir = "ext/html_to_markdown_rb/native"
  ext.source_pattern = "**/*.{rs,toml}"
  ext.platform = "ruby"
end

RSpec::Core::RakeTask.new(:spec)

task spec: :compile
task default: :spec
