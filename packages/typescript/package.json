{
	"name": "@kreuzberg/html-to-markdown-node",
	"version": "3.1.0",
	"description": "High-performance HTML to Markdown converter",
	"license": "MIT",
	"main": "index.js",
	"types": "index.d.ts",
	"repository": "https://github.com/kreuzberg-dev/html-to-markdown",
	"author": "Kreuzberg Team",
	"keywords": [
		"html",
		"markdown",
		"converter"
	],
	"files": [
		"index.js",
		"index.d.ts",
		"**/*.node"
	],
	"scripts": {
		"build": "napi build --manifest-path ../../crates/html-to-markdown-node/Cargo.toml --release",
		"build:debug": "napi build --manifest-path ../../crates/html-to-markdown-node/Cargo.toml",
		"test": "node -e \"console.log('Add test command')\"",
		"typecheck": "tsc --noEmit",
		"lint": "biome check --no-errors-on-unmatched .",
		"lint:fix": "biome check --write --no-errors-on-unmatched .",
		"format": "biome format --write .",
		"format:check": "biome format --no-errors-on-unmatched ."
	},
	"napi": {
		"name": "html-to-markdown-rs",
		"triples": [
			"x86_64-unknown-linux-gnu",
			"x86_64-apple-darwin",
			"aarch64-apple-darwin",
			"x86_64-pc-windows-msvc"
		]
	},
	"devDependencies": {
		"@napi-rs/cli": "^3.6.1"
	}
}
