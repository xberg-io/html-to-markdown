<!-- Outer csproj retained as IDE convenience for opening the whole tree as a project,
     but it is NOT used for packing. The inner `HtmlToMarkdown/HtmlToMarkdown.csproj`
     owns `<PackageId>KreuzbergDev.HtmlToMarkdown</PackageId>` and is the direct
     `dotnet pack` target (see scripts/publish/csharp/pack.sh). -->
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <Nullable>enable</Nullable>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="HtmlToMarkdown/**" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="HtmlToMarkdown/HtmlToMarkdown.csproj" PrivateAssets="all" />
  </ItemGroup>
</Project>
