<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>

    <!-- Package metadata -->
    <PackageId>KreuzbergDev.HtmlToMarkdown</PackageId>
    <Version>3.2.6</Version>
    <LangVersion>latest</LangVersion>
    <Authors>kreuzberg.dev</Authors>
    <Company>kreuzberg.dev</Company>
    <Description>High-performance HTML to Markdown converter with C# bindings to Rust core. Features metadata extraction, visitor pattern, table extraction, and inline image support. 10-80x faster than alternatives.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://kreuzberg.dev</PackageProjectUrl>
    <RepositoryUrl>https://github.com/kreuzberg-dev/html-to-markdown</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>html;markdown;converter;rust;ffi;html-to-markdown;kreuzberg;dotnet;netcore</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="../../../README.md" Pack="true" PackagePath="/" />
    <None Include="runtimes/**" Pack="true" PackagePath="runtimes/" />
  </ItemGroup>

</Project>
