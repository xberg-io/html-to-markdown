[
  {
    "id": "visitor_custom_heading",
    "description": "Visitor replaces heading with custom format",
    "input": {
      "html": "<h2>Section Title</h2><p>Content below heading.</p>"
    },
    "visitor": {
      "callbacks": {
        "visit_heading": {
          "action": "custom_template",
          "template": "--- {text} ---"
        }
      }
    },
    "assertions": [
      {
        "type": "contains",
        "field": "content",
        "value": "--- Section Title ---"
      },
      {
        "type": "not_contains",
        "field": "content",
        "value": "## Section Title"
      },
      {
        "type": "contains",
        "field": "content",
        "value": "Content below heading."
      }
    ]
  }
]
