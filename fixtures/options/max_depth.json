[
  {
    "id": "options_max_depth_exceeds_limit",
    "description": "Conversion returns an error when DOM depth exceeds max_depth",
    "html": "<div><div><div><div><p>Too deep</p></div></div></div></div>",
    "options": { "maxDepth": 2 },
    "assertions": {
      "expect_error": true,
      "error_contains": "max_depth"
    }
  },
  {
    "id": "options_max_depth_within_limit",
    "description": "Conversion succeeds when DOM depth is within max_depth",
    "html": "<div><p>Shallow content</p></div>",
    "options": { "maxDepth": 10 },
    "assertions": {
      "content_contains_all": ["Shallow content"],
      "content_not_empty": true
    }
  },
  {
    "id": "options_max_depth_default_unlimited",
    "description": "Without max_depth, deeply nested HTML converts successfully",
    "html": "<div><div><div><div><div><p>Deep content</p></div></div></div></div></div>",
    "assertions": {
      "content_contains_all": ["Deep content"],
      "content_not_empty": true
    }
  }
]
