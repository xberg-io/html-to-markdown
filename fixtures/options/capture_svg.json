[
  {
    "id": "options_capture_svg_true",
    "description": "Enabling capture_svg processes inline SVG elements when extract_images is on",
    "input": {
      "html": "<p>Below SVG:</p><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"10\" height=\"10\"><rect width=\"10\" height=\"10\" fill=\"red\"/></svg>",
      "options": {
        "extract_images": true,
        "capture_svg": true
      }
    },
    "assertions": [
      {
        "type": "not_empty",
        "field": "content"
      },
      {
        "type": "contains",
        "field": "content",
        "value": "Below SVG"
      }
    ]
  },
  {
    "id": "options_capture_svg_false",
    "description": "Disabling capture_svg still produces content; SVG is not extracted as an image",
    "input": {
      "html": "<p>Below SVG:</p><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"10\" height=\"10\"><rect width=\"10\" height=\"10\" fill=\"red\"/></svg>",
      "options": {
        "extract_images": true,
        "capture_svg": false
      }
    },
    "assertions": [
      {
        "type": "not_empty",
        "field": "content"
      },
      {
        "type": "contains",
        "field": "content",
        "value": "Below SVG"
      }
    ]
  }
]
