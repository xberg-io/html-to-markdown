[
  {
    "id": "semantic_article",
    "description": "Article element wrapping content preserves inner content",
    "input": {
      "html": "<article><h2>Article Title</h2><p>Article body.</p></article>"
    },
    "assertions": [
      {
        "type": "contains_all",
        "field": "content",
        "values": [
          "Article Title",
          "Article body."
        ]
      }
    ]
  },
  {
    "id": "semantic_section_with_heading",
    "description": "Section element with heading preserves structure",
    "input": {
      "html": "<section><h3>Section Heading</h3><p>Section content.</p></section>"
    },
    "assertions": [
      {
        "type": "contains_all",
        "field": "content",
        "values": [
          "Section Heading",
          "Section content."
        ]
      }
    ]
  },
  {
    "id": "semantic_details_summary",
    "description": "Details and summary elements produce readable output",
    "input": {
      "html": "<details><summary>Click to expand</summary><p>Hidden content here.</p></details>"
    },
    "assertions": [
      {
        "type": "not_empty",
        "field": "content"
      },
      {
        "type": "contains_all",
        "field": "content",
        "values": [
          "Click to expand"
        ]
      }
    ]
  },
  {
    "id": "semantic_definition_list",
    "description": "Definition list with term and description",
    "input": {
      "html": "<dl><dt>HTML</dt><dd>HyperText Markup Language</dd><dt>CSS</dt><dd>Cascading Style Sheets</dd></dl>"
    },
    "assertions": [
      {
        "type": "contains_all",
        "field": "content",
        "values": [
          "HTML",
          "HyperText Markup Language",
          "CSS",
          "Cascading Style Sheets"
        ]
      }
    ]
  },
  {
    "id": "semantic_mark_highlight",
    "description": "Mark tag produces highlighted output",
    "input": {
      "html": "<p>This is <mark>highlighted text</mark> in a sentence.</p>"
    },
    "assertions": [
      {
        "type": "not_empty",
        "field": "content"
      },
      {
        "type": "contains_all",
        "field": "content",
        "values": [
          "highlighted text"
        ]
      }
    ]
  },
  {
    "id": "semantic_sub_superscript",
    "description": "Subscript and superscript elements are preserved in output",
    "input": {
      "html": "<p>H<sub>2</sub>O and E=mc<sup>2</sup></p>"
    },
    "assertions": [
      {
        "type": "not_empty",
        "field": "content"
      },
      {
        "type": "contains_all",
        "field": "content",
        "values": [
          "H",
          "2",
          "O",
          "E=mc"
        ]
      }
    ]
  },
  {
    "id": "semantic_abbr",
    "description": "Abbreviation element text is preserved",
    "input": {
      "html": "<p>The <abbr title=\"World Wide Web\">WWW</abbr> is global.</p>"
    },
    "assertions": [
      {
        "type": "contains_all",
        "field": "content",
        "values": [
          "WWW"
        ]
      }
    ]
  },
  {
    "id": "semantic_hr",
    "description": "Horizontal rule produces a separator in output",
    "input": {
      "html": "<p>Above</p><hr><p>Below</p>"
    },
    "assertions": [
      {
        "type": "not_empty",
        "field": "content"
      },
      {
        "type": "contains_all",
        "field": "content",
        "values": [
          "Above",
          "Below"
        ]
      }
    ]
  }
]
