        "type": "not_empty",
        "field": "content"
      },
      {
        "type": "not_empty",
        "field": "document.nodes"
      },
      {
        "type": "count_min",
        "field": "document.nodes",
        "value": 3
      }
    ]
  },
  {
    "id": "structure_sibling_h1_groups",
    "description": "H1, H2, then another H1 creates two sibling top-level groups",
    "input": {
      "html": "<h1>Chapter One</h1><h2>Section A</h2><p>Section A content.</p><h1>Chapter Two</h1><h2>Section B</h2><p>Section B content.</p>",
      "options": {
        "includeDocumentStructure": true
      }
    },
    "assertions": [
      {
        "type": "not_empty",
        "field": "content"
      },
      {
        "type": "not_empty",
        "field": "document.nodes"
      },
      {
        "type": "count_min",
        "field": "document.nodes",
        "value": 4
      }
    ]
  },
  {
    "id": "structure_deep_nesting_h1_h2_h3",
    "description": "H1 > H2 > H3 creates three levels of heading nesting",
    "input": {
      "html": "<h1>Top Level</h1><p>Top intro.</p><h2>Mid Level</h2><p>Mid content.</p><h3>Deep Level</h3><p>Deep content.</p>",
      "options": {
        "includeDocumentStructure": true
      }
    },
    "assertions": [
      {
        "type": "not_empty",
        "field": "content"
      },
      {
        "type": "not_empty",
        "field": "document.nodes"
      },
      {
        "type": "count_min",
        "field": "document.nodes",
        "value": 5
      }
