[
  {
    "id": "structure_h1_h2_nested_group",
    "description": "H1 followed by H2 creates a nested group under the H1",
    "input": {
      "html": "<h1>Chapter One</h1><p>Chapter intro.</p><h2>Section One</h2><p>Section content.</p>",
      "options": {
        "includeDocumentStructure": true
      }
