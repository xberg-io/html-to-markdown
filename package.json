{
	"name": "html-to-markdown-monorepo",
	"version": "3.8.0-rc.2",
	"private": true,
	"description": "HTML to Markdown converter - monorepo root",
	"scripts": {
		"build": "pnpm run build:node && pnpm run build:wasm && pnpm run build:ts",
		"build:node": "pnpm --filter @xberg-io/html-to-markdown run build",
		"build:wasm": "pnpm --filter @xberg-io/html-to-markdown-wasm run build:all",
		"build:ts": "pnpm --filter @xberg-io/html-to-markdown run build",
		"test": "pnpm -r test",
		"test:node": "pnpm --filter @xberg-io/html-to-markdown test",
		"test:wasm": "pnpm --filter @xberg-io/html-to-markdown-wasm test",
		"test:ts": "pnpm --filter @xberg-io/html-to-markdown test",
		"clean": "pnpm -r run clean && rm -rf node_modules",
		"lint": "prek run oxlint --all-files",
		"format": "prek run oxfmt --all-files"
	},
	"devDependencies": {
		"@types/node": "^26.0.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	},
	"engines": {
		"node": ">=18",
		"pnpm": ">=11"
	},
	"packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
