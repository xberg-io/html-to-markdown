{
  "name": "html-to-markdown-monorepo",
  "version": "3.6.0-rc.1",
  "private": true,
  "description": "HTML to Markdown converter - monorepo root",
  "scripts": {
    "build": "pnpm run build:node && pnpm run build:wasm && pnpm run build:ts",
    "build:node": "pnpm --filter @kreuzberg/html-to-markdown-node run build",
    "build:wasm": "pnpm --filter @kreuzberg/html-to-markdown-wasm run build:all",
    "build:ts": "pnpm --filter @kreuzberg/html-to-markdown run build",
    "test": "pnpm -r test",
    "test:node": "pnpm --filter @kreuzberg/html-to-markdown-node test",
    "test:wasm": "pnpm --filter @kreuzberg/html-to-markdown-wasm test",
    "test:ts": "pnpm --filter @kreuzberg/html-to-markdown test",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "lint": "prek run oxlint --all-files",
    "format": "prek run oxfmt --all-files"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1"
}
